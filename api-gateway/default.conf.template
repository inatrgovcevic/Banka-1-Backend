# api-gateway/default.conf.template
#
# PR_19 C19.X: posle KONSOLIDACIJE 15→7 servisa, controlleri u konsolidovanim
# servisima (user, banking-core, market, trading) imaju eksplicitne prefiks-e
# (/employees/auth, /accounts/client, /api/cards, /transactions, /transfers,
# /verification, /stock, /exchange, /order/portfolio itd) tako da nginx
# prosto prosledjuje request bez prefix stripping-a i bez X-Forwarded-Prefix-a.
# X-Forwarded-Prefix sa SB 4.0.3 FRAMEWORK strategy-jem dupli prefiks na
# servletPath i kvari routing.

server {
    listen 80;
    server_name localhost;

    client_max_body_size 25m;

    # === CORS (server-wide) ===
    # Reflect-origin za localhost dev. add_header je allowed u `server` kontekstu,
    # NIJE u `if in server`. `always` flag obavezan da headers prolaze i kroz 4xx/5xx.
    #
    # KRITICNO: Spring Boot upstream-i emit-uju Access-Control-* headers preko
    # WebMvc CORS support-a. Ako i gateway add_header-uje, browser vidi DUPLE
    # vrednosti ("http://localhost:4200, http://localhost:4200") i odbija request.
    # Resenje: `proxy_hide_header` u svakom proxy_pass bloku skida upstream CORS
    # headers PRE nego sto add_header iz server scope-a emit-uje nase.
    set $cors_origin "";
    if ($http_origin ~* ^(https?://localhost(:[0-9]+)?|https?://127\.0\.0\.1(:[0-9]+)?)$) {
        set $cors_origin $http_origin;
    }
    add_header Access-Control-Allow-Origin       $cors_origin always;
    add_header Access-Control-Allow-Credentials  "true" always;
    add_header Access-Control-Allow-Methods      "GET, POST, PUT, PATCH, DELETE, OPTIONS" always;
    add_header Access-Control-Allow-Headers      "Authorization, Content-Type, X-Api-Key, X-Requested-With, X-Correlation-Id, Accept, Origin" always;
    add_header Access-Control-Expose-Headers     "Location, X-Correlation-Id" always;
    add_header Access-Control-Max-Age            "3600" always;

    # Skinuti CORS headers koje upstream sam emit-uje (Spring Boot servisi imaju
    # svoj WebMvc CORS, Go chi sad ima cors middleware) — gateway je single source
    # of truth.
    proxy_hide_header Access-Control-Allow-Origin;
    proxy_hide_header Access-Control-Allow-Credentials;
    proxy_hide_header Access-Control-Allow-Methods;
    proxy_hide_header Access-Control-Allow-Headers;
    proxy_hide_header Access-Control-Expose-Headers;
    proxy_hide_header Access-Control-Max-Age;

    # Short-circuit all CORS preflight requests before they reach any backend.
    # Backends must never see OPTIONS — their auth middleware rejects it with 401.
    if ($request_method = OPTIONS) {
        return 204;
    }

    # Resolve service names at request time so the gateway can start for a
    # partial Go-only stack; unused Java upstreams do not need to exist.
    resolver 127.0.0.11 valid=10s ipv6=off;
    set $user_service http://user-service:${USER_SERVICE_PORT};
    set $market_service http://market-service:${MARKET_SERVICE_PORT};
    set $banking_core_service http://banking-core-service:${BANKING_CORE_SERVICE_PORT};
    set $trading_service http://trading-service:${TRADING_SERVICE_PORT};
    set $credit_service http://credit-service:${CREDIT_SERVER_PORT};
    set $notification_service http://notification-service:${NOTIFICATION_SERVICE_PORT};
    set $saga_orchestrator_service http://saga-orchestrator-service:${SAGA_SERVICE_PORT};
    set $interbank_service http://interbank-service:${INTERBANK_SERVICE_PORT};

    # === Go service health checks through gateway ===
    location = /health/user {
        proxy_pass $user_service/actuator/health/readiness;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location = /health/market {
        proxy_pass $market_service/actuator/health/readiness;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # === User domain (employee + client; konsolidovano u user-service) ===

    # Frontend legacy auth refresh/logout endpoints.
    location /auth/ {
        # Use the resolver variable like every other block — a literal
        # `http://user_service` is an undefined upstream and makes nginx fail at
        # startup ("host not found in upstream user_service"). Pre-existing bug.
        proxy_pass $user_service;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Exact /employees (Spring CrudController @GetMapping at /employees, no trailing slash)
    location = /employees {
        proxy_pass $user_service/employees$is_args$args;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
    location /employees/ {
        proxy_pass $user_service;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location = /clients {
        proxy_pass $user_service/clients$is_args$args;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
    location /clients/ {
        proxy_pass $user_service;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # === Banking core domain (account/card/transaction/transfer/verification) ===

    location /accounts/ {
        proxy_pass $banking_core_service;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /api/cards/ {
        proxy_pass $banking_core_service;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
