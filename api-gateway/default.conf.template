    }
    location /negotiations/ {
        proxy_pass $interbank_service;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Tim 2 MINOR-1 (P2.1): spec-default user lookup path /user/{rn}/{id}.
    # Regex match ogranicava na /user/<digits>/<id> da ne kolidira sa nicim
    # drugim. /interbank/user/{rn}/{id} ostaje kao backward-compatible alias
    # pokriven /interbank/ prefiks blokom iznad.
    location ~ ^/user/[0-9]+/[A-Za-z0-9_.-]+$ {
        proxy_pass $interbank_service;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Health check
    location /gateway-health {
        access_log off;
        return 200 'API Gateway is running safely!\n';
        add_header Content-Type text/plain;
    }
}
