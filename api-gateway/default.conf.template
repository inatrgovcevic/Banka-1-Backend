        proxy_pass $banking_core_service/payment-recipients$is_args$args;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
    location /payment-recipients/ {
        proxy_pass $banking_core_service;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # === Market domain (stock + exchange) ================================

    # /exchange/* — controllers at /rates, /calculate (no prefix); strip /exchange/
    location = /exchange {
        return 301 /exchange/;
    }
    location /exchange/ {
        # Strip the /exchange prefix. nginx does NOT prefix-strip when proxy_pass uses
        # a variable, so do it explicitly (otherwise the upstream receives only "/").
        rewrite ^/exchange/(.*)$ /$1 break;
        proxy_pass $market_service;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # /stock/* — legacy stock-service controllers at /api/listings, /admin/stocks (no prefix); strip
    location = /stock {
        return 301 /stock/;
    }
    location /stock/ {
        # Strip the /stock prefix (variable proxy_pass needs an explicit rewrite,
        # else market-service receives only "/").
        rewrite ^/stock/(.*)$ /$1 break;
        proxy_pass $market_service;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # /stocks/* — consolidated market-service own controllers (StockInfoController re-prefixed in PR_19)
    location = /stocks {
        return 301 /stocks/;
    }
    location /stocks/ {
        proxy_pass $market_service;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location = /price-alerts {
