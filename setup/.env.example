BANKING_SERVER_PORT=8084
BANKING_DB_HOST=postgres
BANKING_DB_PORT=5432
BANKING_DB_NAME=bankingdb
BANKING_DB_USER=postgres
BANKING_DB_PASSWORD=postgres
