STOCK_DB_PORT=5432
STOCK_DB_NAME=stock_db
STOCK_DB_USER=postgres
STOCK_DB_PASSWORD=postgres
STOCK_EXCHANGE_SERVICE_URL=http://exchange-service:8085
STOCK_MARKET_DATA_BASE_URL=https://www.alphavantage.co
ALPHA_VANTAGE_API_KEY=NMBJV9I1JXOWWEZ6

# =========================
# Exchange Service
# =========================
EXCHANGE_SERVER_PORT=8085
EXCHANGE_DB_HOST=postgres
EXCHANGE_DB_PORT=5432
EXCHANGE_DB_NAME=exchange_db
EXCHANGE_DB_USER=postgres
