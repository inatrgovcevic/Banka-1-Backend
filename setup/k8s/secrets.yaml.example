  POSTGRES_PASSWORD: REPLACE_ME
  POSTGRES_HOST: db-pgbouncer
  POSTGRES_PORT: "5432"
  POSTGRES_DB: notification_db
  USER_SERVICE_DB_USER: postgres
  USER_SERVICE_DB_PASSWORD: REPLACE_ME
  BANKING_CORE_DB_HOST: db-pgbouncer
  BANKING_CORE_DB_PORT: "5432"
  BANKING_CORE_DB_NAME: banking_core
  BANKING_CORE_DB_USER: postgres
  BANKING_CORE_DB_PASSWORD: REPLACE_ME
  MARKET_SERVICE_DB_HOST: db-pgbouncer
  MARKET_SERVICE_DB_PORT: "5432"
  MARKET_SERVICE_DB_NAME: market_service
  MARKET_SERVICE_DB_USER: postgres
  MARKET_SERVICE_DB_PASSWORD: REPLACE_ME
  TRADING_DB_HOST: db-pgbouncer
  TRADING_DB_PORT: "5432"
  TRADING_DB_NAME: trading
  TRADING_DB_USER: postgres
  TRADING_DB_PASSWORD: REPLACE_ME
  CREDIT_DB_HOST: db-pgbouncer
  CREDIT_DB_PORT: "5432"
