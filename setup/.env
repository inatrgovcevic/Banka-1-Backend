# Dev / handshake test env. NOT for production.
JWT_SECRET=dev-jwt-secret-do-not-use-in-prod
INTERBANK_PROFILE=dev
SAGA_PROFILE=dev

# Bank identity
BANKA1_ROUTING_NUMBER=111
BANKA1_DISPLAY_NAME=Banka 1
BANKA2_ROUTING_NUMBER=222
BANKA2_DISPLAY_NAME=Banka 2

# Partner endpoint (defaults to in-process mock; override for cross-bank)
BANKA2_BASE_URL=http://interbank-service:8091/_mock/banka2/
BANKA2_INBOUND_TOKEN=dev-inbound-banka2-to-banka1
BANKA2_OUTBOUND_TOKEN=dev-outbound-banka1-to-banka2

# Enable in-process mock partner so /interbank works without Java cohort
INTERBANK_MOCK_PARTNER_ENABLED=true

# Postgres
DB_USER=postgres
DB_PASSWORD=postgres
INTERBANK_DB_USER=postgres
INTERBANK_DB_PASSWORD=postgres
INTERBANK_DB_NAME=interbank_service

# RabbitMQ
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# Third-party market data APIs (Spring @NotBlank validates these; demo defaults
# pa servis startuje. Real keys u prod-u kroz Vault/CI secret.)
TWELVE_DATA_API_KEY=demo
ALPHA_VANTAGE_API_KEY=demo

# Tools
DISCORD_BOT_TOKEN=
DEVELOPER_DISCORD_ID=
